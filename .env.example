# Backend API origin (no trailing slash).
# Dev: leave empty — Vite proxies /api → http://localhost:8080 (start my-utils-api first).
# Prod: public API origin the browser can reach (NOT 127.0.0.1 on the server).
# Example: https://utils-api.rus-crafting.ru
# If nginx serves UI + /api on one host: leave empty.
VITE_API_BASE_URL=

# Grafana iframe (Observability tab). Leave empty to embed same-origin /grafana/ (nginx proxy).
# Example: https://grafana.example.com or /grafana
VITE_GRAFANA_URL=
# Optional path inside Grafana, e.g. explore or dashboards/f/xyz
VITE_GRAFANA_PATH=
