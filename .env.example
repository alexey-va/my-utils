# Backend API origin (no trailing slash).
# Dev: leave empty — Vite proxies /api → http://localhost:8080 (start my-utils-api first).
# Prod: public API origin the browser can reach (NOT 127.0.0.1 on the server).
# Example: https://utils-api.rus-crafting.ru
# If nginx serves UI + /api on one host: leave empty.
VITE_API_BASE_URL=

# Grafana iframe — same-origin /grafana/ (nginx → 127.0.0.1:3500). Required for login in iframe.
# Do not point at grafana.rus-crafting.ru in iframe (third-party cookies → login loop).
VITE_GRAFANA_URL=
# Path after /grafana/ when opening the Grafana tab. Default: dashboards (browse all).
VITE_GRAFANA_PATH=dashboards

# Temporal iframe — same-origin /temporal/ (nginx → 127.0.0.1:18233). Requires TEMPORAL_UI_PUBLIC_PATH=/temporal on temporal-ui.
# Do not point at temporal.alexeyav.ru in iframe (third-party context).
VITE_TEMPORAL_URL=
# Path after /temporal/ when opening the Temporal tab. Default: empty (Temporal home).
VITE_TEMPORAL_PATH=
